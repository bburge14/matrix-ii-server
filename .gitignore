# Compiled files
bin/
*.class

# Large dependencies that can be downloaded separately  
lib/*.jar

# Cache and data files
# (anchored with leading slash so it only matches top-level cache dirs -
# don't catch src/com/rs/cache/ which is a Java package, not the game cache.)
/cache/
/*_cache/
main_file_cache.dat2
main_file_cache.idx*

# Log files
logs/
*.log

# Player data
data/saves/
data/characters/

# Temporary files
*.tmp
*.temp
*.data
